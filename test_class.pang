on("flag", () => {
    class Foo {
        constructor(x, y) {
            print(x + y, {seconds: 2});
            print(this, {seconds: 2})
        }
        bar() {
            print("bar");
            let foo = 5;
            for (let i = 0; i < foo; i++) {
                print(i, {seconds: 1});
            }
        }
    }

    let a: Foo = new Foo(5, 10);
    a.bar();
    //a = {bar: () => {return 1}};
    //a.bar();
    print(typeof a); // Foo
});
