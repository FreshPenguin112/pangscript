on("flag", *{
    let name = ask("What is your name?");
    name = name != "Joe" ? name : "Evil Joe";
    if (name == "Alice") {
        print("Hello, Alice the Great!", {seconds: 2});
    } else if (name == "Bob") {
        print("Hello, Bob the Great!", {seconds: 2});
    } else {
        print("Hello, " .. name .. "!", {seconds: 2});
    }
});