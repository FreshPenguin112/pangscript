{
    "dependencies": {
        "@babel/core": "^7.28.5",
        "@babel/plugin-transform-modules-commonjs": "^7.27.1",
        "antlr4": "^4.13.2"
    },
    "scripts": {
        "build": "antlr4ng -o ./lib -Dlanguage=JavaScript -visitor -listener *.g4 && babel ./lib --out-dir ./lib --plugins=@babel/plugin-transform-modules-commonjs"
    },
    "devDependencies": {
        "antlr4ng": "^3.0.16"
    }
}
