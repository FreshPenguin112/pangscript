{
  "dependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.5",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "antlr4": "^4.13.2"
  },
  "devDependencies": {
    "antlr4ng": "^3.0.16"
  },
  "scripts": {
    "build": "java -jar antlr-4.13.2-complete.jar -o ./lib -Dlanguage=JavaScript -visitor -listener *.g4 && bunx babel ./lib --out-dir ./lib --plugins=@babel/plugin-transform-modules-commonjs"
  }
}
