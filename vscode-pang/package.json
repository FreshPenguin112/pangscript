{
  "name": "pang-language",
  "displayName": "Pang Language",
  "publisher": "freshpenguin112",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": ["Programming Languages"],
  "main": "./dist/extension.js",
  "activationEvents": ["onLanguage:pang", "workspaceContains:**/*.ps", "onStartupFinished", "onCommand:pang.restartLanguageServer", "onCommand:pang.installDependencies"],
  "scripts": {
    "prepackage": "node ./scripts/bundle.js",
    "build:bundle": "node ./scripts/bundle.js",
    "package": "vsce package --allow-missing-repository",
    "postinstall": "node ./node-postinstall.js || true"
  },
  "files": [
    "dist/**",
    "server/dist/**",
    "syntaxes/**",
    "snippets/**",
    "language-configuration.json",
    "README.md"
  ],
  "devDependencies": {
    "vsce": "^2.9.0",
    "vscode-languageclient": "^9.0.1",
    "vscode-languageserver": "^9.0.1",
    "esbuild": "^0.17.19"
  },
  "contributes": {
    "languages": [
      {
        "id": "pang",
        "aliases": ["Pang", "pang"],
        "extensions": [".ps"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "pang",
        "scopeName": "source.pang",
        "path": "./syntaxes/pang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "pang",
        "path": "./snippets/pang.json"
      }
    ]
    ,
    "commands": [
      {
        "command": "pang.restartLanguageServer",
        "title": "Pang: Restart Language Server"
      }
      ,
      {
        "command": "pang.installDependencies",
        "title": "Pang: Install Extension Dependencies"
      }
    ]
  }
}
